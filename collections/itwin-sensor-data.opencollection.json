{
  "opencollection": "1.0.0",
  "info": {
    "name": "iTwin Sensor Data API",
    "version": "1.0"
  },
  "request": {
    "auth": {
      "type": "oauth2",
      "flow": "authorization_code",
      "authorizationUrl": "https://ims.bentley.com/connect/authorize",
      "accessTokenUrl": "https://ims.bentley.com/connect/token",
      "credentials": {
        "clientId": "{{clientId}}",
        "clientSecret": "{{clientSecret}}"
      }
    }
  },
  "items": [
    {
      "info": {
        "name": "Devices",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Get Devices",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.bentley.com/sensor-data/devices"
          },
          "docs": "Get Devices"
        },
        {
          "info": {
            "name": "Create Device",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "https://api.bentley.com/sensor-data/devices",
            "body": {
              "type": "json",
              "data": "{}"
            }
          },
          "docs": "Create Device"
        }
      ]
    },
    {
      "info": {
        "name": "Sensors",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Get Sensors",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.bentley.com/sensor-data/sensors"
          },
          "docs": "Get Sensors"
        },
        {
          "info": {
            "name": "Create Sensor",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "https://api.bentley.com/sensor-data/sensors",
            "body": {
              "type": "json",
              "data": "{}"
            }
          },
          "docs": "Create Sensor"
        }
      ]
    },
    {
      "info": {
        "name": "Observations",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Get Observations",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.bentley.com/sensor-data/observations"
          },
          "docs": "Get Observations"
        },
        {
          "info": {
            "name": "Create Observation",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "https://api.bentley.com/sensor-data/observations",
            "body": {
              "type": "json",
              "data": "{}"
            }
          },
          "docs": "Create Observation"
        }
      ]
    }
  ],
  "bundled": true
}